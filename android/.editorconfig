root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kts,kt}]
indent_size = 4
max_line_length = 120

[*.{xml,json,toml,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# Compose composable functions use PascalCase — disable the function-naming rule
# for the UI layer where @Composable functions like InkBridgeTheme live.
[{app/src/main/kotlin/com/inkbridge/ui/**,app/src/main/kotlin/com/inkbridge/app/ui/**}]
ktlint_standard_function-naming = disabled
